SITE_URL=https://www.depology.com

# Volcengine authentication.
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
VOLCENGINE_REGION=cn-north-1
VOLCENGINE_SERVICE=cv

# Ark Platform (Seedream 4.5), get credentials from https://console.volcengine.com/ark
ARK_API_KEY=
ARK_MODEL=
ARK_GUIDANCE_SCALE=2.5
ARK_SIZE=2048x2048

# JiMeng image generation settings (legacy Seedream 4.0).
VOLCENGINE_API_HOST=visual.volcengineapi.com
VOLCENGINE_ACTION=CVSync2AsyncSubmitTask
VOLCENGINE_VERSION=2022-08-31
VOLCENGINE_GET_ACTION=CVSync2AsyncGetResult
VOLCENGINE_GET_VERSION=2022-08-31
JIMENG_REQ_KEY=jimeng_t2i_v40
JIMENG_I2I_REQ_KEY=jimeng_i2i_v30
JIMENG_I2I_SCALE=0.3
JIMENG_WIDTH=1024
JIMENG_HEIGHT=1024
JIMENG_RETURN_URL=true
TEST_PROMPT=Luxury skincare ad, premium serum bottle on a clean vanity, soft daylight, glossy product photography, elegant beauty campaign, high detail

# Batch execution defaults.
IMAGE_PROVIDER=
CONCURRENCY=1
RETRIES=2
RETRY_BASE_MS=1200
RETRY_MAX_MS=12000
RESUME=true

# Output tuning.
OUTPUT_DIR=output
DOWNLOAD_IMAGES=true
MAX_POLL_ATTEMPTS=20
POLL_INTERVAL_MS=5000

# Feishu Bitable sync.
FEISHU_BITABLE_ENABLED=false
FEISHU_NATIVE_IMAGE_ENABLED=true
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_MEDIA_PARENT_TYPE=bitable_file
FEISHU_MEDIA_PARENT_NODE=
FEISHU_SOURCE_SYSTEM=ai-image
FEISHU_WORKFLOW=ads-image-runner

# Field names in your Bitable table.
FEISHU_FIELD_PRIMARY=Record Title
FEISHU_FIELD_RUN_ID=Run ID
FEISHU_FIELD_SOURCE=Source System
FEISHU_FIELD_WORKFLOW=Workflow
FEISHU_FIELD_PROVIDER=Provider
FEISHU_FIELD_CONCEPT_ID=Concept ID
FEISHU_FIELD_SCENE=Scene
FEISHU_FIELD_STATUS=Status
FEISHU_FIELD_PROMPT=Prompt
FEISHU_FIELD_IMAGE_URL=Image URL
FEISHU_FIELD_IMAGE_ATTACHMENT=Image
FEISHU_FIELD_LOCAL_PATH=Local Path
FEISHU_FIELD_TASK_ID=Task ID
FEISHU_FIELD_GENERATED_AT=Generated At
FEISHU_FIELD_LINK_KEY=Link Key
FEISHU_FIELD_EDM_CAMPAIGN_ID=EDM Campaign ID
FEISHU_FIELD_EDM_FLOW_ID=EDM Flow ID
FEISHU_FIELD_ERROR=Error

# Optional EDM linkage metadata.
EDM_CAMPAIGN_ID=
EDM_FLOW_ID=
