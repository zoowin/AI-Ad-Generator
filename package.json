{
  "name": "depology-ad-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Automated ad image generation agent for Depology using JiMeng AI on Volcengine.",
  "scripts": {
    "start": "node src/run.js",
    "dry-run": "node src/run.js --dry-run",
    "brand": "node src/run.js --brand-only",
    "batch": "node src/run.js --mode img2img",
    "local-dry-run": "node src/localDryRun.js",
    "import-meta-competitor": "node src/importMetaCompetitor.js",
    "build-input-index": "node src/buildInputIndex.js",
    "build-workspace-catalog": "node src/buildWorkspaceCatalog.js",
    "filter-static-ad-library": "node src/filterStaticAdLibrary.js"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
